# CONFIGURACIÓN DE BASE DE DATOS - AUDIT LOG TRIGGERS
# 🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙🮙🮘🮙🮘🮙
# Archivo plantilla para variables de entorno de conexión a PostgreSQL
# Copiar a database.env y configurar con valores reales para desarrollo local

# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# CONEXIÓN BÁSICA A POSTGRESQL
# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Host del servidor PostgreSQL (localhost para desarrollo, IP/hostname para producción)
POSTGRES_HOST=localhost

# Puerto de PostgreSQL (5432 es el puerto por defecto)
POSTGRES_PORT=5432

# Nombre de la base de datos para el proyecto de auditoría
POSTGRES_DB=auditlog_triggers_db

# Usuario de PostgreSQL (crear usuario específico para este proyecto)
POSTGRES_USER=auditlog_admin

# Contraseña del usuario (USAR CONTRASEÑA SEGURA en producción)
POSTGRES_PASSWORD=change_me_in_production

#Usuario root (para crear base de datos si es necesario)
POSTGRES_ROOT_USER=postgres

#Contraseña del usuario root
POSTGRES_ROOT_PASSWORD=change_me_in_production

# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# CONFIGURACIÓN DE POOL DE CONEXIONES (OPCIONAL)
# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Tamaño del pool de conexiones (recomendado: 5-20 para desarrollo, 20-50 para producción)
# POSTGRES_POOL_SIZE=10

# Conexiones adicionales permitidas sobre el pool (recomendado: 5-10)
# POSTGRES_MAX_OVERFLOW=5

# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# CONFIGURACIÓN DEL PROYECTO
# ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Entorno de ejecución (development, test, production)
PROJECT_ENV=development

# Habilitar/deshabilitar sistema de auditoría (true/false)
AUDIT_ENABLED=true

# ▁▂▃▄▅▆▇███████ Notas de seguridad ███████▇▆▅▄▃▂▁ 

# - NUNCA commitear el archivo database.env con credenciales reales
# - Usar contraseñas seguras y diferentes por entorno
# - En producción, usar variables de entorno del sistema o secret manager
# - Considerar usar SSL para conexiones a PostgreSQL en producción